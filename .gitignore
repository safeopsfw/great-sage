# Model weights (10-30 GB, binary)
models/

# Database files (personal data + large binary)
data/*.db
data/*.db-shm
data/*.db-wal

# FAISS index (regenerated from knowledge.db)
faiss/

# Automated backups (managed separately)
backup/

# Runtime logs (rotated automatically)
logs/

# Drop zone files (transient)
incoming/*.pdf
incoming/*.txt
incoming/*.docx
incoming/*.md

# Training output (uploaded to Colab, not stored in Git)
training/merged/
training/deployed/

# Python runtime artifacts
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# Python virtual environment
venv/
.venv/
env/

# Rust build output
target/
services/orchestrator/target/

# Go build output
services/gateway/bin/

# HuggingFace cache
hf_cache/

# OS and editor artifacts
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/settings.json
*.swp
*.swo

# Secrets (never commit)
.env
*.env
secrets.toml
